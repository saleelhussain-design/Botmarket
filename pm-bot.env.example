# PM Bot Environment Configuration
# Copy this file to .env and fill in your actual values

#############################
# Environment
#############################
ENVIRONMENT=production  # production, staging, or development
DEBUG=false

#############################
# Database Configuration
#############################
DB_HOST=192.168.1.201
DB_PORT=3306
DB_NAME=botmarket
DB_USER=pm_bot_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

#############################
# Twilio (WhatsApp)
#############################
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+971501234567

#############################
# Email (SMTP)
#############################
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@botmarket.ae
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM=PM Bot <notifications@botmarket.ae>
SMTP_TO=admin@botmarket.ae

#############################
# API Keys
#############################
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

#############################
# Security
#############################
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
API_KEY=CHANGE_ME_RANDOM_32_CHAR_STRING
ALLOWED_ORIGINS=https://botmarket.ae,https://pm.botmarket.ae

#############################
# PM Bot Settings
#############################
PM_BOT_PORT=5001
PM_BOT_HOST=0.0.0.0
TASK_CHECK_INTERVAL=300  # seconds (5 minutes)
REMINDER_ADVANCE_HOURS=24  # Send reminders 24h before deadline

#############################
# Monitoring
#############################
SENTRY_DSN=https://xxx@sentry.io/xxx
UPTIME_KUMA_URL=http://192.168.1.204:3001
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

#############################
# Backup Settings
#############################
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
